# Copy this file to .streamlit/secrets.toml (gitignored — never pushed) and
# fill in your real connection string to test locally against the cloud
# Postgres database instead of the local SQLite file.
#
# This is optional — with no secrets.toml at all, the app uses local
# SQLite by default, which is the normal way to run it locally.
#
# Get the connection string from: Supabase dashboard -> your project ->
# Settings -> Database -> Connection string -> "Session pooler" or
# "Transaction pooler" (NOT "Direct connection" -- see CLOUD_DEPLOYMENT.md
# for why). Use only letters/digits in the database password so it never
# needs URL-encoding.

# DATABASE_URL = "postgresql://postgres.<project-ref>:<password>@aws-<n>-<region>.pooler.supabase.com:6543/postgres"
